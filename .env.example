# Copy this file to ".env" and paste your key(s). The real .env is gitignored, so keys never
# get committed. Run the pipeline with:  node --env-file=.env pipeline/agentic/run.mjs --promote
#
# All keys are OPTIONAL. With none set, the pipeline runs fully on free/offline providers.

# FREE real vision judge (Google AI Studio -> "Get API key"): https://aistudio.google.com/apikey
# Paste the key after the = sign, no quotes.
GEMINI_API_KEY=

# Optional: override the free Gemini model (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Paid premium judge (Anthropic). If set, it takes priority over Gemini.
# ANTHROPIC_API_KEY=

# Image generation provider: "mock" (offline) or "pollinations" (FREE real AI art, needs internet)
IMAGE_PROVIDER=pollinations
